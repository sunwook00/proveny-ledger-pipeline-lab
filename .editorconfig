root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.java]
indent_size = 4

[*.kt]
indent_size = 4

[*.kts]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
max_line_length = 120

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

[*.sql]
indent_size = 4
